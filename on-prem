name: Deploy to Local Server

on:
  push:
    branches: [ main ]

jobs:
  deploy:
    runs-on: self-hosted  # This tells it to run on YOUR machine
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Copy files to Nginx directory
        run: |
          sudo cp -r ./* /var/www/html/
          sudo systemctl restart nginx
